      "name": "Token",
      "description": {
        "content": "Token exchange using private_key_jwt or PKCE.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "ca63df8a-d16e-4a20-9374-c8cd822d2430",
          "name": "Exchange Authorization Code for Tokens",
          "request": {
            "name": "Exchange Authorization Code for Tokens",
            "description": {
              "content": "Exchanges the authorization code for an `access_token` and a signed `id_token`. Web apps\nauthenticate using `private_key_jwt`; native apps use PKCE with a `code_verifier`.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "openid_connect",
                "token"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "disabled": false,
                  "key": "grant_type",
                  "value": "<string>",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "key": "code",
                  "value": "<string>",
                  "description": "(Required) Authorization code returned from `/openid_connect/authorize`."
                },
                {
                  "disabled": false,
                  "key": "client_assertion_type",
                  "value": "<string>",
                  "description": "Required for private_key_jwt clients."
                },
                {
                  "disabled": false,
                  "key": "client_assertion",
                  "value": "<string>",
                  "description": "Signed JWT (RS256) where `iss` and `sub` are `client_id`, `aud` is the token endpoint, and `jti`, `iat`, `exp` are set. Minimum 2048-bit key."
                },
                {
                  "disabled": false,
                  "key": "code_verifier",
                  "value": "<string>",
                  "description": "PKCE code verifier matching the original `code_challenge`. Used by native apps in lieu of `client_assertion`."
                }
              ]
            }
          },
          "response": [
            {
              "id": "55008f20-dfc9-4278-9daa-1d19c0b2e434",
              "name": "Token response.",
