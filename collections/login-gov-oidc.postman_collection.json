    {
      "id": "fa95536e-5f3a-494a-b0d9-facf33070b3b",
      "name": "Logout",
      "description": {
        "content": "RP-initiated logout and session termination.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "a700891f-dffc-426e-9dbb-75ee8a71f607",
          "name": "RP-Initiated Logout",
          "request": {
            "name": "RP-Initiated Logout",
            "description": {
              "content": "Ends the user's Login.gov session. After confirmation the browser is redirected to the\npre-registered `post_logout_redirect_uri` with the original `state` value.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "openid_connect",
                "logout"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "client_id",
                  "value": "<string>",
                  "description": "(Required) Registered relying party identifier."
                },
                {
                  "disabled": false,
                  "key": "post_logout_redirect_uri",
                  "value": "<uri>",
                  "description": "(Required) Pre-registered post-logout redirect URI."
                },
                {
                  "disabled": false,
                  "key": "state",
                  "value": "<string>",
                  "description": "Opaque value (minimum 22 characters) echoed back to `post_logout_redirect_uri`."
                }
              ],
              "variable": []
            },
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "58e742a9-b01d-440d-b470-18a0c68f8901",
              "name": "Redirect back to `post_logout_redirect_uri` after the user confirms logout.",
              "originalRequest": {
                "url": {
                  "path": [
                    "openid_connect",
                    "logout"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
