    {
      "id": "e0dff3fc-8dda-4403-9f44-b81ff732c656",
      "name": "Authorization",
      "description": {
        "content": "OAuth 2.0 authorization endpoint where the user authenticates.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "0bccb841-b9d5-4868-85ff-51856e535fe9",
          "name": "Start Authorization Flow",
          "request": {
            "name": "Start Authorization Flow",
            "description": {
              "content": "Begins the OIDC authorization code flow. The user is redirected to Login.gov, authenticates,\nconsents to the requested scopes, and is redirected back to `redirect_uri` with an\nauthorization `code` and the original `state` value.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "openid_connect",
                "authorize"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "client_id",
                  "value": "<string>",
                  "description": "(Required) Registered relying party identifier."
                },
                {
                  "disabled": false,
                  "key": "response_type",
                  "value": "<string>",
                  "description": "(Required) Must be `code`. Implicit flow is not supported."
                },
                {
                  "disabled": false,
                  "key": "scope",
                  "value": "<string>",
                  "description": "(Required) Space-separated list of requested scopes. Must include `openid`."
                },
                {
                  "disabled": false,
                  "key": "redirect_uri",
                  "value": "<uri>",
                  "description": "(Required) Pre-registered redirect URI. Must match exactly."
                },
                {
                  "disabled": false,
                  "key": "nonce",
                  "value": "<string>",
                  "description": "(Required) Random string (minimum 22 characters) bound to the id_token to prevent replay."
                },
                {
                  "disabled": false,
                  "key": "state",
                  "value": "<string>",
                  "description": "(Required) Opaque value (minimum 22 characters) returned with the callback for CSRF protection and request/callback correlation."
                },
                {
                  "disabled": false,
                  "key": "prompt",
                  "value": "<string>",
                  "description": "(Required) Must be `select_account`."
                },
                {
                  "disabled": false,
                  "key": "acr_values",
                  "value": "<string>",
                  "description": "Requested authentication context. Combines a service level and an authenticator assurance level."
                },
                {
                  "disabled": false,
                  "key": "locale",
                  "value": "<string>",
                  "description": "Override the user's locale."
                },
                {
                  "disabled": false,
                  "key": "code_challenge",
                  "value": "<string>",
                  "description": "PKCE code challenge (base64url SHA-256 of `code_verifier`). Required for native apps using PKCE instead of private_key_jwt."
                },
                {
                  "disabled": false,
                  "key": "code_challenge_method",
                  "value": "<string>",
                  "description": "PKCE method. Login.gov supports `S256`."
                }
              ],
              "variable": []
            },
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "f5344aaf-f244-4ffd-bd3e-d54bf82a7712",
              "name": "Redirect to Login.gov for authentication, then back to `redirect_uri` with `code` and `state`.",
              "originalRequest": {
                "url": {
                  "path": [
                    "openid_connect",
                    "authorize"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "client_id",
                      "value": "<string>"
                    },
                    {
                      "key": "response_type",
                      "value": "<string>"
                    },
                    {
                      "key": "scope",
                      "value": "openid email profile"
                    },
                    {
                      "key": "redirect_uri",
                      "value": "<uri>"
                    },
                    {
                      "key": "nonce",
                      "value": "<string>"
                    },
                    {
                      "key": "state",
                      "value": "<string>"
                    },
                    {
                      "key": "prompt",
                      "value": "<string>"
                    },
                    {
                      "key": "acr_values",
                      "value": "urn:acr.login.gov:auth-only http://idmanagement.gov/ns/assurance/aal/2"
                    },
                    {
                      "key": "locale",
                      "value": "<string>"
                    },
                    {
                      "key": "code_challenge",
                      "value": "<string>"
                    },
                    {
                      "key": "code_challenge_method",
                      "value": "<string>"
                    }
                  ],
                  "variable": []
                },
                "method": "GET",
                "body": {}
              },
              "status": "Found",
              "code": 302,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/plain"
                }
              ],
              "body": "",
              "cookie": [],
              "_postman_previewlanguage": "text"
            }
          ],
          "event": [],
