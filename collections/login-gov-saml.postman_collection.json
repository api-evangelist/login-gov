        {
          "id": "a11039d0-7384-4cd2-8d6f-23f19cd60eb4",
          "name": "Initiate SAML SSO (HTTP-Redirect)",
          "request": {
            "name": "Initiate SAML SSO (HTTP-Redirect)",
            "description": {
              "content": "Accepts a Base64-encoded, DEFLATE-compressed `SAMLRequest` via HTTP-Redirect.\nThe user authenticates with Login.gov and the IdP responds with a signed SAML\nassertion POSTed to the SP's Assertion Consumer Service URL.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "saml",
                "auth2026"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "SAMLRequest",
                  "value": "<string>",
                  "description": "(Required) Base64-encoded DEFLATE-compressed AuthnRequest."
                },
                {
                  "disabled": false,
                  "key": "RelayState",
                  "value": "<string>",
                  "description": "Opaque value echoed back in the SAML response."
                },
                {
                  "disabled": false,
                  "key": "SigAlg",
                  "value": "<string>",
                  "description": "Signature algorithm URI when the request is signed."
                },
                {
                  "disabled": false,
                  "key": "Signature",
                  "value": "<string>",
                  "description": "Base64-encoded signature over the request."
                }
              ],
              "variable": []
            },
            "method": "GET",
            "auth": null
          },
          "response": [
